# Supabase — Frontend (öffentlich, in Vite via VITE_ Prefix)
VITE_SUPABASE_URL=https://DEIN_PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Supabase — Backend / ICS-Feed + Cron (geheim, nur auf Vercel)
SUPABASE_URL=https://DEIN_PROJEKT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cron — schützt /api/cron (Vercel sendet ihn als "Authorization: Bearer …").
# Frei wählbarer, langer Zufallswert. Wenn nicht gesetzt, ist der Endpunkt ungeschützt.
CRON_SECRET=

# Zeitzone der Serverless Functions. Muss auf Europe/Berlin stehen, damit der Cron
# die Woche/Slots identisch zum Browser berechnet (Vercel läuft sonst in UTC).
TZ=Europe/Berlin
